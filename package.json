{
  "name": "feishubot",
  "version": "0.1.0",
  "private": true,
  "description": "Feishu bot that routes messages by recognized intent (code understanding / bug fix / knowledge QA / chat).",
  "main": "dist/app.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "ts-node src/app.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/app.js",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  }
}
