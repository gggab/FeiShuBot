# Feishu
APP_ID=
APP_SECRET=
LARK_DOMAIN=https://open.feishu.cn

# LLM (OpenAI-compatible)
LLM_PROVIDER=deepseek
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL=deepseek-chat
INTENT_MODEL=
INTENT_MIN_CONFIDENCE=0.5

# Local CLI
CLI_PROVIDER=claude
CLI_BIN=
# Headless/container auth for the CLI binaries themselves (not read by this app's
# own config; inherited by the spawned CLI process). See docs/deployment.md §4.
# CLAUDE_CODE_OAUTH_TOKEN=
# CODEX_API_KEY=
CLI_TIMEOUT_MS=300000
# Bug fix (write) timeout; locating + editing takes longer (default 20 min).
BUGFIX_TIMEOUT_MS=1200000
# codex only: true => --sandbox danger-full-access (disables codex's bwrap sandbox).
# MUST be true in Docker (bwrap can't set up a netns/loopback there); docker-compose.yml
# already sets it for the feishubot service. Keep false for native local dev. See docs/handlers.md §6.
CODEX_UNSANDBOXED=false
# Worktree base dir for bug fixes (default = system temp, auto-expanded to a long path
# to avoid Windows 8.3 short names like LIAOWE~1 which Claude's safety blocks).
WORKTREE_DIR=

# /repos scope + project intros (routing). See docs/handlers.md §9.
# Root for code-understanding (common parent of all registered repos). Empty = derive from projects.json.
REPOS_ROOT=
# Intro dir name relative to REPOS_ROOT (one <alias>.md per project, kept outside the repos).
AGENT_INTROS_DIR=.agent-intros
# Intro "regenerate" thresholds since last generation (else incremental update).
INTRO_REGEN_FILES=8
INTRO_REGEN_LINES=400
# Refresh scheduling: debounce window for bursts of /git changes, and min interval
# between two refreshes of the same project (prevents thrashing on frequent branch switches).
INTRO_REFRESH_DEBOUNCE_MS=20000
INTRO_REFRESH_MIN_INTERVAL_MS=600000

# Bug fix / GitLab MR workflow
GITLAB_BASE_URL=
GITLAB_TOKEN=
GIT_DEFAULT_BASE_BRANCH=test
FIX_BRANCH_PREFIX=fix/

# Code-modification authorization (fail-closed: both empty => nobody may modify code).
# Department allowlist is primary; person allowlist is the fallback. Files are git-ignored.
# Person entries: open_id (ou_...) or email (needs contact email-field scope). Mixed OK.
BUGFIX_ALLOWLIST_FILE=bugfix-allowlist.json
BUGFIX_ALLOWLIST=
# Allowed department ids (open_department_id). Needs contact:contact.base:readonly to resolve user depts.
BUGFIX_ALLOWED_DEPARTMENTS_FILE=bugfix-allowed-departments.json
BUGFIX_ALLOWED_DEPARTMENTS=

# Code-understanding (read source) access authorization (fail-closed: both empty => nobody may read).
# Group entries: chat_id (oc_...). Person entries: open_id (ou_...) or email. Mixed OK.
# Files are git-ignored.
CODE_READ_ALLOWED_CHATS_FILE=code-read-allowed-chats.json
CODE_READ_ALLOWED_CHATS=
CODE_READ_ALLOWLIST_FILE=code-read-allowlist.json
CODE_READ_ALLOWLIST=

# Dify (not wired yet)
DIFY_BASE_URL=
DIFY_API_KEY=

# Service
PORT=3000
SESSION_MAX_TURNS=10
LOG_LEVEL=info

# Session persistence (SQLite single-file). Off by default => in-memory only.
# When true, conversation context survives process restarts; keyed by chat_id.
SESSION_PERSIST=false
# SQLite file path (git-ignored).
SESSION_DB_FILE=session.db
# Per-chat hard cap of archived messages (oldest pruned beyond this).
SESSION_STORE_MAX_MESSAGES=200
# Delete messages older than N days (0 = keep forever).
SESSION_RETENTION_DAYS=365

# Project registry: prefer a git-ignored file (see projects.example.json).
# File path (default projects.json); falls back to inline PROJECTS_JSON if absent.
PROJECTS_FILE=projects.json
PROJECTS_JSON=
# Feishu open_id -> GitLab user: file (default usermap.json) or inline USER_MAP_JSON.
USER_MAP_FILE=usermap.json
USER_MAP_JSON=
